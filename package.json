{
  "name": "dialectic-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @dialectic/mobile",
    "app": "yarn workspace @dialectic/app",
    "macos": "yarn workspace @dialectic/macos",
    "windows": "yarn workspace @dialectic/windows",
    "build:app": "yarn workspace @dialectic/app build",
    "test:app": "yarn workspace @dialectic/app test",
    "test:mobile": "yarn workspace @dialectic/mobile test",
    "lint:mobile": "yarn workspace @dialectic/mobile lint"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  },
  "packageManager": "yarn@4.12.0"
}
