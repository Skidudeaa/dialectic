# ============================================================
# Dialectic — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- REQUIRED ----

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres@localhost/dialectic

# Anthropic API key (primary LLM provider)
ANTHROPIC_API_KEY=sk-ant-...

# ---- OPTIONAL ----

# OpenAI API key (fallback LLM + vector embeddings)
# Without this, LLM fallback and semantic memory search won't work.
OPENAI_API_KEY=sk-...

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Production mode (disables reload, uses multiple workers)
# PRODUCTION=1

# Number of uvicorn workers in production mode
# WEB_CONCURRENCY=2

# JWT secret for auth tokens (auto-generated if not set)
# JWT_SECRET=your-secret-here
